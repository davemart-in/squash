{
  "name": "squash",
  "version": "1.0.0",
  "description": "Squash em bugs",
  "main": "src/index.ts",
  "scripts": {
    "dev": "concurrently -n api,ui -c blue,magenta \"tsx watch src/index.ts\" \"cd src/ui && npx vite dev\"",
    "build": "cd src/ui && npx vite build --outDir ../../src/api/public --emptyOutDir",
    "start": "node dist/index.js",
    "db:reset": "rm -f squash.db && tsx -e \"import './src/db/schema.js'\" && echo 'squash: database reset'",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/davemart-in/squash.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/davemart-in/squash/issues"
  },
  "homepage": "https://github.com/davemart-in/squash#readme",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.83",
    "@anthropic-ai/sdk": "^0.80.0",
    "@types/express": "^5.0.6",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "uuid": "^13.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
